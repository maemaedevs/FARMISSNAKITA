PORT=8080

# Example Postgres connection string (update if your local credentials differ)
DATABASE_URL=postgresql://farmis:farmis@localhost:5432/farmis?schema=public

# Local DB: from this folder run `docker compose up -d` then `npm run prisma:migrate`

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173

# Mobile OTP (bcrypt-hashed in DB; dev delivery logs to server console)
OTP_TTL_SECONDS=300
OTP_LENGTH=4
OTP_MAX_VERIFY_ATTEMPTS=5

